# Copy this file to .env and fill in real values. Never commit .env itself.

# Supabase Postgres — Project Settings → Database in the Supabase dashboard.
# DATABASE_URL: pooled connection (port 6543, pgbouncer) — used by the app at runtime.
# DIRECT_URL: direct connection (port 5432) — used only for running migrations.
# If the password contains special characters (?, #, /, @, :), percent-encode
# them (e.g. "?" -> "%3F") or the connection string will fail to parse.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres"

ANTHROPIC_API_KEY=

# Gates the whole app behind a single shared password (middleware.ts) — set
# this in Vercel's env vars before/immediately after deploying, since anyone
# with the deployed URL otherwise sees your real profile (no auth, single
# shared database, no per-visitor isolation). Leave unset locally if you
# don't want the gate in dev.
SITE_PASSWORD=
