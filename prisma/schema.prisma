// Prisma schema for Meally.
// Postgres (Supabase) in production and local dev alike. DATABASE_URL is the
// pooled (pgbouncer, port 6543) connection used at runtime; DIRECT_URL is the
// direct (port 5432) connection Prisma needs for migrations, since pgbouncer's
// transaction mode doesn't support the prepared statements migrate uses.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum GoalType {
  LOSE
  MAINTAIN
  GAIN
}

enum PlanStatus {
  DRAFT
  ACCEPTED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model Profile {
  id                  String        @id @default(cuid())
  // Supabase auth.users.id (UUID). auth.users lives in Supabase's own "auth"
  // schema, not one Prisma introspects, so this is a plain string column with
  // no Prisma-level relation — the link is enforced in application code, not
  // the database.
  userId              String        @unique
  weightKg            Float
  heightCm            Float
  age                 Int
  sex                 Sex
  activityLevel       ActivityLevel
  dietaryPreferences  String // JSON-encoded string[]
  conditions          String // JSON-encoded string[]
  goalType            GoalType
  goalWeightKg        Float?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  weightLogs           WeightLog[]
  nutritionPlans       NutritionPlan[]
  dislikedIngredients  DislikedIngredient[]
  progressFeedback     ProgressFeedback?
  mealLogs             MealLog[]
}

model WeightLog {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  weightKg  Float
  loggedAt  DateTime @default(now())
}

model NutritionPlan {
  id            String     @id @default(cuid())
  profileId     String
  profile       Profile    @relation(fields: [profileId], references: [id])
  version       Int        @default(1)
  status        PlanStatus @default(DRAFT)
  calories      Int
  proteinG      Int
  carbsG        Int
  fatG          Int
  sugarG        Int
  fiberG        Int
  researchNotes String // Claude's rationale / citations
  createdAt     DateTime   @default(now())

  mealPlans MealPlan[]
}

model DislikedIngredient {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  name      String
  addedAt   DateTime @default(now())

  @@unique([profileId, name])
}

model MealPlan {
  id              String     @id @default(cuid())
  nutritionPlanId String
  nutritionPlan   NutritionPlan @relation(fields: [nutritionPlanId], references: [id])
  weekStartDate   DateTime
  status          PlanStatus @default(DRAFT)
  createdAt       DateTime   @default(now())

  days MealPlanDay[]
}

model MealPlanDay {
  id         String   @id @default(cuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id])
  dayOfWeek  Int // 0 = Monday .. 6 = Sunday
  date       DateTime

  meals Meal[]

  @@unique([mealPlanId, dayOfWeek])
}

model Meal {
  id            String      @id @default(cuid())
  mealPlanDayId String
  mealPlanDay   MealPlanDay @relation(fields: [mealPlanDayId], references: [id])
  type          MealType
  name          String
  description   String
  ingredients   String // JSON-encoded string[]
  calories      Int
  proteinG      Int
  carbsG        Int
  fatG          Int
  sugarG        Int
  fiberG        Int
  prepMinutes   Int     @default(20) // estimated active prep + cook time
  sourceUrl     String? // recipe URL, if this meal was imported from one
  notes         String? // e.g. adjustments/exclusions Claude made when importing a recipe

  logs MealLog[]
}

model MealLog {
  id         String   @id @default(cuid())
  // Direct link to the owning profile — necessary because mealId is
  // nullable (an orphaned log, its Meal deleted by a regeneration, keeps
  // its history but loses the only other path back to a profile). Without
  // this, every MealLog query across all users returns everyone's rows
  // once there's more than one profile.
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id])
  mealId     String?
  meal       Meal?    @relation(fields: [mealId], references: [id])
  loggedAt   DateTime @default(now())
  name       String // snapshot in case the meal/plan changes later
  calories   Int
  proteinG   Int
  carbsG     Int
  fatG       Int
  sugarG     Int
  fiberG     Int
  notes      String?
}

model ProgressFeedback {
  id          String   @id @default(cuid())
  profileId   String   @unique
  profile     Profile  @relation(fields: [profileId], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  summary     String
  doingWell   String // JSON-encoded string[]
  improve     String // JSON-encoded string[]
  createdAt   DateTime @default(now())
}
